<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_isp_amenity_form.etechflow_isp_amenity_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Amenity</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\BackButton"/>
            <button name="delete" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\DeleteButton"/>
            <button name="save" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\SaveButton"/>
        </buttons>
        <namespace>etechflow_isp_amenity_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_isp_amenity_form.etechflow_isp_amenity_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_isp_amenity_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="ETechFlow\InStorePickup\Ui\Component\Form\AmenityDataProvider"
                      name="etechflow_isp_amenity_form_data_source">
            <settings>
                <requestFieldName>amenity_id</requestFieldName>
                <primaryFieldName>amenity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Amenity Details</label>
        </settings>

        <field name="amenity_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>amenity_id</dataScope>
            </settings>
        </field>
        <field name="label" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
                <notice translate="true">Display label — e.g. "Free parking", "Free coffee", "Wheelchair accessible".</notice>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="code" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <dataScope>code</dataScope>
                <notice translate="true">Short URL-safe identifier — letters, numbers, dashes only.</notice>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="icon" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Icon</label>
                <dataScope>icon</dataScope>
                <notice translate="true">Optional. Tabler Icons name (e.g. "parking", "coffee", "wheelchair", "dog"). Leave empty for a generic dot. See https://tabler-icons.io/ for the catalogue.</notice>
            </settings>
        </field>
        <field name="sort_order" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Sort Order</label>
                <dataScope>sort_order</dataScope>
            </settings>
        </field>
        <field name="is_active" formElement="checkbox">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
                <prefer>toggle</prefer>
                <valueMap>
                    <map name="false" xsi:type="number">0</map>
                    <map name="true" xsi:type="number">1</map>
                </valueMap>
            </settings>
        </field>
    </fieldset>
</form>
