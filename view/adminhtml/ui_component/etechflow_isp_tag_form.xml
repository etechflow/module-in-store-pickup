<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_isp_tag_form.etechflow_isp_tag_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Store Tag</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="ETechFlow\InStorePickup\Block\Adminhtml\Tag\BackButton"/>
            <button name="delete" class="ETechFlow\InStorePickup\Block\Adminhtml\Tag\DeleteButton"/>
            <button name="save" class="ETechFlow\InStorePickup\Block\Adminhtml\Tag\SaveButton"/>
        </buttons>
        <namespace>etechflow_isp_tag_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_isp_tag_form.etechflow_isp_tag_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_isp_tag_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="ETechFlow\InStorePickup\Ui\Component\Form\TagDataProvider"
                      name="etechflow_isp_tag_form_data_source">
            <settings>
                <requestFieldName>tag_id</requestFieldName>
                <primaryFieldName>tag_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Tag Details</label>
        </settings>

        <field name="tag_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>tag_id</dataScope>
            </settings>
        </field>
        <field name="label" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
                <notice translate="true">Badge text — e.g. "Flagship", "Drive-through", "Express Collection".</notice>
                <tooltip>
                    <description translate="true">Short word or phrase shown as a badge next to stores that have this tag. Tags help customers filter the store-locator and signal store characteristics. Examples: "Flagship", "24/7 lockers", "Drive-through", "Express", "New Branch". Keep under 20 chars so the badge fits.</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="code" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <dataScope>code</dataScope>
                <notice translate="true">URL-safe identifier — letters, numbers, dashes only. Also a CSS class hook on the storefront filter.</notice>
                <tooltip>
                    <description translate="true">Permanent unique handle used in URLs, the database, AND as a CSS class on the storefront (e.g. code "flagship" → class="etf-tag-flagship") so themes can style tag badges differently. Pick short and descriptive ("flagship", "drive-thru", "express-collection"). CANNOT be changed after save.</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-code" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="colour" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Colour</label>
                <dataScope>colour</dataScope>
                <notice translate="true">Optional. Hex code (#fbbf24) or Tailwind keyword (amber, sky, emerald). Drives the badge tint.</notice>
                <tooltip>
                    <description translate="true">Colour for the tag badge. Two formats supported: (1) Hex code with leading # (e.g. "#fbbf24" for amber). (2) Tailwind palette name (e.g. "amber", "sky", "emerald", "rose", "violet") — themes that use Tailwind translate this to the correct shade automatically. Leave blank for a neutral grey badge. Pick colours that don't clash with your storefront theme.</description>
                </tooltip>
            </settings>
        </field>
        <field name="sort_order" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Sort Order</label>
                <dataScope>sort_order</dataScope>
                <notice translate="true">Display order in the storefront tag filter. Lower = first. Use 10, 20, 30…</notice>
                <tooltip>
                    <description translate="true">When stores have multiple tags, this controls which appears first. Use multiples of 10 for easy insertion (e.g. add "New Branch" as 15 between "Flagship" 10 and "Express" 20).</description>
                </tooltip>
            </settings>
        </field>
        <!-- v1.1.8: see amenity_form.xml for the toggle → select rationale. -->
        <field name="is_active" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
                <notice translate="true">Yes = show badge + filter on storefront. No = hide without deleting.</notice>
                <tooltip>
                    <description translate="true">Inactive tags are hidden on the storefront (no badge, not in filter) but kept in admin + still associated with their stores. Use for seasonal tags or to temporarily remove without losing store associations.</description>
                </tooltip>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
