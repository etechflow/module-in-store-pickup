<?xml version="1.0"?>
<!--
    v2.0 architecture change:

    The v1.x picker card list at `checkout.shipping.methods.before`
    is replaced by the modal — clicking the single "Pick up in store"
    radio opens the picker overlay (location → date → time). The old
    PickupStorePicker block remains in code for backwards-compat with
    any project pinning ^1.x, but the v2.0 layout doesn't render it.

    v2.0 wires:
    - <head> loads pickup-modal.css + pickup-modal.js (always — they're
      tiny and the JS no-ops when the modal element isn't on page)
    - The modal phtml is mounted into checkout.shipping.methods.after
      so it lives in the same DOM region as the radios it listens to.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="ETechFlow_InStorePickup::css/pickup-modal.css"/>
        <script src="ETechFlow_InStorePickup::js/pickup-modal.js"/>
    </head>
    <body>
        <referenceContainer name="checkout.shipping.methods.after">
            <block class="Magento\Framework\View\Element\Template"
                   name="etechflow.isp.checkout.pickup_modal"
                   template="ETechFlow_InStorePickup::checkout/pickup-modal.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>
