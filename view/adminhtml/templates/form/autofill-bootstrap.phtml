    msiSourceCopyUrl: '<?= $escaper->escapeJs($block->getMsiSourceCopyUrl()); ?>',
    formKey: '<?= $escaper->escapeJs($block->getFormKey()); ?>'
};
</script>
<script src="<?= $escaper->escapeUrl($jsUrl); ?>" defer></script>
