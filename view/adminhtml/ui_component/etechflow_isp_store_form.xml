                    <dataScope>hours_6_is_closed</dataScope>
                </settings>
                <formElements>
                    <select>
                        <settings>
                            <options class="Magento\Config\Model\Config\Source\Yesno"/>
                        </settings>
                    </select>
                </formElements>
            </field>
            <field name="hours_6_open_time" formElement="input" sortOrder="20">
                <settings>
                    <dataType>text</dataType>
                    <label translate="true">Open</label>
                    <dataScope>hours_6_open_time</dataScope>
                    <placeholder translate="true">HH:MM</placeholder>
                </settings>
            </field>
            <field name="hours_6_close_time" formElement="input" sortOrder="30">
                <settings>
                    <dataType>text</dataType>
                    <label translate="true">Close</label>
                    <dataScope>hours_6_close_time</dataScope>
                    <placeholder translate="true">HH:MM</placeholder>
                </settings>
            </field>
        </container>
    </fieldset>

    <fieldset name="exceptions">
        <settings>
            <label translate="true">Exception Days</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <hint translate="true">One-off date overrides for this store — bank holidays, stocktake days, reduced hours. Add a row per exception. Leave empty if this store follows the regular weekly hours every day of the year.</hint>
        </settings>
        <htmlContent name="exceptions_tz_note">
            <block name="exceptions_tz_note_block"
                   class="ETechFlow\InStorePickup\Block\Adminhtml\Form\TimezoneNote"/>
        </htmlContent>
        <dynamicRows name="exceptions">
            <settings>
                <addButtonLabel translate="true">Add Exception Day</addButtonLabel>
                <componentType>dynamicRows</componentType>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <deleteProperty>delete</deleteProperty>
                <deleteValue>true</deleteValue>
                <recordTemplate>record</recordTemplate>
                <dataScope>exceptions</dataScope>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">false</param>
                </dndConfig>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="exception_date" formElement="date">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Date</label>
                        <dataScope>exception_date</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                    <formElements>
                        <date>
                            <settings>
                                <options>
                                    <option name="dateFormat" xsi:type="string">y-MM-dd</option>
                                </options>
                            </settings>
                        </date>
                    </formElements>
                </field>
                <field name="is_closed" formElement="select">
                    <settings>
                        <dataType>number</dataType>
                        <label translate="true">Closed</label>
                        <dataScope>is_closed</dataScope>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                            </settings>
                        </select>
                    </formElements>
                </field>
                <field name="open_time" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Open</label>
                        <dataScope>open_time</dataScope>
                        <placeholder translate="true">HH:MM</placeholder>
                    </settings>
                </field>
                <field name="close_time" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Close</label>
                        <dataScope>close_time</dataScope>
                        <placeholder translate="true">HH:MM</placeholder>
                    </settings>
                </field>
                <field name="reason" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Reason</label>
                        <dataScope>reason</dataScope>
                        <placeholder translate="true">e.g. Stocktake, Christmas Eve</placeholder>
                    </settings>
                </field>
                <actionDelete>
                    <settings>
                        <componentType>actionDelete</componentType>
                        <dataType>text</dataType>
                        <label/>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>

    <fieldset name="window_overrides">
        <settings>
            <label translate="true">Pickup Window Overrides</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <hint translate="true">By default this store offers every active pickup window at the global capacity. Only add rows here if you want to disable a window for this store or set a different capacity. Empty = behaves like every other store.</hint>
        </settings>
        <dynamicRows name="window_overrides">
            <settings>
                <addButtonLabel translate="true">Add Window Override</addButtonLabel>
                <componentType>dynamicRows</componentType>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <deleteProperty>delete</deleteProperty>
                <deleteValue>true</deleteValue>
                <recordTemplate>record</recordTemplate>
                <dataScope>window_overrides</dataScope>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">false</param>
                </dndConfig>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="window_id" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">window_overrides</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>number</dataType>
                        <label translate="true">Window</label>
                        <dataScope>window_id</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="ETechFlow\InStorePickup\Model\Source\PickupWindowOptions"/>
                            </settings>
                        </select>
                    </formElements>
                </field>
                <field name="is_disabled" formElement="select">
                    <settings>
                        <dataType>number</dataType>
                        <label translate="true">Disabled for this Store</label>
                        <dataScope>is_disabled</dataScope>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                            </settings>
                        </select>
                    </formElements>
                </field>
                <field name="capacity_override" formElement="input">
                    <settings>
                        <dataType>number</dataType>
                        <label translate="true">Capacity Override</label>
                        <dataScope>capacity_override</dataScope>
                        <notice translate="true">Leave blank to use the window's global capacity.</notice>
                    </settings>
                </field>
                <actionDelete>
                    <settings>
                        <componentType>actionDelete</componentType>
                        <dataType>text</dataType>
                        <label/>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>

    <fieldset name="amenities">
        <settings>
            <label translate="true">Amenities</label>
            <collapsible>true</collapsible>
            <hint translate="true">What this store offers — free parking, free coffee, wheelchair accessibility, etc. Manage the catalogue under In-Store Pickup → Amenities. Only active amenities appear in the picker below.</hint>
        </settings>
        <field name="assigned_amenity_ids" formElement="multiselect">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">etechflow_isp_store</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Assigned Amenities</label>
                <dataScope>assigned_amenity_ids</dataScope>
                <notice translate="true">What this store offers. Manage the catalogue under In-Store Pickup → Amenities. Only active amenities appear here.</notice>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="ETechFlow\InStorePickup\Model\Source\AmenityOptions"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="tags">
        <settings>
            <label translate="true">Tags</label>
            <collapsible>true</collapsible>
            <hint translate="true">Tags drive front-end filtering on the store locator — flagship store, drive-through, express collection, etc. Manage the catalogue under In-Store Pickup → Store Tags.</hint>
        </settings>
        <field name="assigned_tag_ids" formElement="multiselect">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">etechflow_isp_store</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Assigned Tags</label>
                <dataScope>assigned_tag_ids</dataScope>
                <notice translate="true">Tags drive front-end filtering on the store locator. Manage the catalogue under In-Store Pickup → Store Tags.</notice>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="ETechFlow\InStorePickup\Model\Source\TagOptions"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
    </fieldset>
</form>
