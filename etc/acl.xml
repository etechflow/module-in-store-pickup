<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Config::config">
                        <resource id="ETechFlow_InStorePickup::config"
                                  title="ETechFlow In-Store Pickup Configuration"
                                  sortOrder="100"/>
                    </resource>
                </resource>
                <resource id="ETechFlow_InStorePickup::menu"
                          title="In-Store Pickup"
                          sortOrder="100">
                    <resource id="ETechFlow_InStorePickup::stores"
                              title="Stores"
                              sortOrder="10"/>
                    <resource id="ETechFlow_InStorePickup::holidays"
                              title="Holidays"
                              sortOrder="20"/>
                    <resource id="ETechFlow_InStorePickup::tags"
                              title="Store Tags"
                              sortOrder="30"/>
                    <resource id="ETechFlow_InStorePickup::amenities"
                              title="Amenities"
                              sortOrder="40"/>
                    <resource id="ETechFlow_InStorePickup::pickup_windows"
                              title="Pickup Windows"
                              sortOrder="50"/>
                    <resource id="ETechFlow_InStorePickup::mark_pickup_ready"
                              title="Mark Pickup Order Ready"
                              sortOrder="60"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
