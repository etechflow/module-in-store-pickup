<?php
declare(strict_types=1);

/**
 * Hyvä Checkout pickup-store informational card (v1.3.1).
 *
 * Companion to ETechFlow\InStorePickup\Block\Checkout\PickupStorePicker.
 *
 * v1.3.1 design pivot: strict informational card, zero JS dependency.
 *
 * v1.3.0 attempted an Alpine.js interactive picker (click a card → find +
 * click the matching shipping-method radio → autofill fires). Three+ hours
 * of vendor/ debugging on Keystation showed Alpine hydrated correctly
 * (proxy in _x_dataStack) but @click handlers never fired. Likely culprits
 * (un-confirmed): Magento CSP stripping inline event-attribute equivalents,
 * Hyvä Checkout intercepting clicks at a higher capture phase, or HTML
 * purification removing Alpine's @-prefixed attributes. None reproducible
 * without local browser DevTools + a Hyvä developer to nail down.
 *
 * Rather than keep chasing it, v1.3.1 makes the card purely informational:
 *   - Lists the active pickup stores with name + address + phone
 *   - Ends with a brief instruction: "Select your preferred store from
 *     the shipping methods below"
 *   - No clicks, no JS, no framework dependency
 *
 * The customer reads the cards, then picks the matching shipping-method
 * radio in the standard Magento radio list below the picker (one radio
 * per store, courtesy of the carrier). That radio click commits the
 * shipping method, which fires ShippingAddressAutofillPlugin, which
 * overrides the shipping address with the picked store's address (the
 * tax-bug-kill differentiator we have over every competing C&C module).
 *
 * Trade-off: customer scrolls a few inches to commit instead of one-tap.
 * Acceptable for a v1 ship. The interactive picker can come back in
 * v2.0 once the Alpine/CSP/Hyvä-Checkout interaction is properly
 * debugged in a local environment.
 *
 * @var \ETechFlow\InStorePickup\Block\Checkout\PickupStorePicker $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isPickerEnabled()) {
    return;
}

$stores = $block->getActiveStores();
?>
<div id="etechflow-isp-picker" class="my-6">
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">
            <?= $escaper->escapeHtml(__('Pick up in store')) ?>
        </h3>

        <p class="mt-1 text-sm text-slate-600">
            <?= $escaper->escapeHtml(__('Free Click &amp; Collect from any of our shops:')) ?>
        </p>

        <ul class="mt-4 space-y-3">
            <?php foreach ($stores as $store):
                $address = $block->formatAddress($store);
                ?>
                <li class="rounded-md border border-slate-200 bg-slate-50 p-3">
                    <div class="text-sm font-semibold text-slate-900">
                        <?= $escaper->escapeHtml($store['name']) ?>
                    </div>
                    <?php if ($address !== ''): ?>
                        <div class="mt-0.5 text-xs text-slate-600">
                            <?= $escaper->escapeHtml($address) ?>
                        </div>
                    <?php endif; ?>
                    <?php if ($store['phone'] !== ''): ?>
                        <div class="mt-0.5 text-xs text-slate-500">
                            <?= $escaper->escapeHtml($store['phone']) ?>
                        </div>
                    <?php endif; ?>
                </li>
            <?php endforeach; ?>
        </ul>

        <p class="mt-4 rounded-md bg-blue-50 px-3 py-2.5 text-xs text-blue-900">
            <strong><?= $escaper->escapeHtml(__('To collect:')) ?></strong>
            <?= $escaper->escapeHtml(__('Select your preferred shop from the shipping methods list below. We\'ll email you when your order is ready and provide a PIN to collect.')) ?>
        </p>
    </div>
</div>
