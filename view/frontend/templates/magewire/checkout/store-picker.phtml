<?php
declare(strict_types=1);

/**
 * Magewire-native store picker template for Hyvä Checkout.
 *
 * Companion to ETechFlow\InStorePickup\Magewire\Checkout\StorePicker.
 *
 * The root <div> is required — Magewire binds component state to the
 * first HTML element. Adding or removing it breaks state hydration.
 *
 * @var \ETechFlow\InStorePickup\Magewire\Checkout\StorePicker $magewire
 * @var \Magento\Framework\Escaper $escaper
 */
?>
<?php if (!$magewire->enabled || empty($magewire->stores)): ?>
    <div></div>
<?php else: ?>
<div id="etechflow-isp-magewire" class="my-6"
     wire:loading.class="opacity-60 pointer-events-none">

    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-baseline justify-between gap-4">
            <h3 class="text-base font-semibold text-slate-900">
                <?= $escaper->escapeHtml(__('Pick up in store')) ?>
            </h3>
            <?php if ($magewire->selectedStoreCode !== ''): ?>
                <button type="button"
                        wire:click="clearSelection"
                        class="text-sm font-medium text-blue-600 hover:text-blue-700 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">
                    <?= $escaper->escapeHtml(__('Change store')) ?>
                </button>
            <?php endif; ?>
        </div>

        <p class="mt-1 text-sm text-slate-500">
            <?= $escaper->escapeHtml(__('Pick a shop to collect from. We\'ll email you when your order is ready.')) ?>
        </p>

        <!-- Store list — server-rendered cards -->
        <div class="mt-4 space-y-2">
            <?php foreach ($magewire->stores as $store):
                $isSelected = $store['code'] === $magewire->selectedStoreCode;

                $cardClass = 'block w-full text-left rounded-lg border p-4 transition '
                    . 'focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 '
                    . ($isSelected
                        ? 'border-blue-500 bg-blue-50 ring-1 ring-blue-300'
                        : 'border-slate-200 bg-white hover:border-slate-300 hover:bg-slate-50 cursor-pointer');

                $address = $magewire->formatAddress($store);
                ?>
                <button type="button"
                        wire:click="pickStore('<?= $escaper->escapeJs($store['code']) ?>')"
                        class="<?= $escaper->escapeHtmlAttr($cardClass) ?>"
                        aria-pressed="<?= $isSelected ? 'true' : 'false' ?>">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <strong class="text-sm font-semibold text-slate-900 truncate">
                                    <?= $escaper->escapeHtml($store['name']) ?>
                                </strong>
                                <?php if ($isSelected): ?>
                                    <span class="inline-flex items-center rounded-full bg-blue-600 px-2 py-0.5 text-[10px] font-semibold text-white">
                                        <?= $escaper->escapeHtml(__('Selected')) ?>
                                    </span>
                                <?php endif; ?>
                            </div>
                            <?php if ($address !== ''): ?>
                                <div class="mt-0.5 text-xs text-slate-600">
                                    <?= $escaper->escapeHtml($address) ?>
                                </div>
                            <?php endif; ?>
                            <?php if ($store['phone'] !== ''): ?>
                                <div class="mt-0.5 text-xs text-slate-500">
                                    <?= $escaper->escapeHtml($store['phone']) ?>
                                </div>
                            <?php endif; ?>
                        </div>
                        <div class="flex-shrink-0 mt-0.5">
                            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border-2 <?= $isSelected ? 'border-blue-600 bg-blue-600' : 'border-slate-300' ?>">
                                <?php if ($isSelected): ?>
                                    <svg class="h-3 w-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                    </svg>
                                <?php endif; ?>
                            </span>
                        </div>
                    </div>
                </button>
            <?php endforeach; ?>
        </div>

        <!-- Selection summary -->
        <?php if ($magewire->selectedStoreCode !== ''): ?>
            <div class="mt-4 rounded-md bg-blue-50 px-3 py-2.5 text-sm text-blue-900">
                <div class="flex items-start gap-2">
                    <svg class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div class="flex-1">
                        <strong class="font-semibold"><?= $escaper->escapeHtml(__('Picked: %1', $magewire->selectedName)) ?></strong>
                        <?php if ($magewire->selectedInstructions !== ''): ?>
                            <div class="mt-1 text-xs text-blue-800">
                                <?= $escaper->escapeHtml($magewire->selectedInstructions) ?>
                            </div>
                        <?php endif; ?>
                        <div class="mt-1 text-xs text-blue-700">
                            <?= $escaper->escapeHtml(__('We\'ll email you when your order is ready for pickup.')) ?>
                        </div>
                    </div>
                </div>
            </div>
        <?php endif; ?>

        <!-- Hidden inputs — surface the picked store into Hyvä Checkout's POST payload.
             Names mirror Magento's standard quote/order extension-attribute conventions. -->
        <input type="hidden"
               name="extension_attributes[etechflow_isp_store_code]"
               value="<?= $escaper->escapeHtmlAttr($magewire->selectedStoreCode) ?>"/>
    </div>
</div>
<?php endif; ?>
