<?php
declare(strict_types=1);

/**
 * Hyvä Checkout pickup-store picker template (v1.3.0).
 *
 * Companion to ETechFlow\InStorePickup\Block\Checkout\PickupStorePicker.
 * Replaces the v1.2.x Magewire template — pure server-render + Alpine.js,
 * no Magewire round-trips.
 *
 * Alpine state:
 *   selected — current visually-selected store code ('' = none)
 *   pick(code) — set selected + click the matching shipping-method radio
 *                so the autofill plugin fires (carrier method
 *                "etechflow_isp_<code>")
 *
 * @var \ETechFlow\InStorePickup\Block\Checkout\PickupStorePicker $block
 * @var \Magento\Framework\Escaper $escaper
 */

if (!$block->isPickerEnabled()) {
    return;
}

$stores       = $block->getActiveStores();
$methodPrefix = $block->getMethodPrefix();
?>
<div id="etechflow-isp-picker" class="my-6"
     x-data="{
         selected: '',
         pick(code) {
             this.selected = code;
             // Find the matching shipping-method radio. Magento checkout
             // standardly uses input[type=radio][name=shipping_method].
             // Hyvä Checkout may wrap differently — selector tries both
             // the canonical name= form and a fallback by value alone.
             const value = '<?= $escaper->escapeJs($methodPrefix) ?>' + code;
             let target = document.querySelector(
                 'input[type=radio][name=&quot;shipping_method&quot;][value=&quot;' + value + '&quot;]'
             );
             if (!target) {
                 target = document.querySelector(
                     'input[type=radio][value=&quot;' + value + '&quot;]'
                 );
             }
             if (target) {
                 target.click();
                 target.dispatchEvent(new Event('change', { bubbles: true }));
             }
         }
     }">

    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-baseline justify-between gap-4">
            <h3 class="text-base font-semibold text-slate-900">
                <?= $escaper->escapeHtml(__('Pick up in store')) ?>
            </h3>
            <button type="button"
                    x-show="selected !== ''"
                    @click="selected = ''"
                    class="text-sm font-medium text-blue-600 hover:text-blue-700 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded">
                <?= $escaper->escapeHtml(__('Change store')) ?>
            </button>
        </div>

        <p class="mt-1 text-sm text-slate-500">
            <?= $escaper->escapeHtml(__('Pick a shop to collect from. We\'ll email you when your order is ready.')) ?>
        </p>

        <div class="mt-4 space-y-2">
            <?php foreach ($stores as $store):
                $code    = $store['code'];
                $address = $block->formatAddress($store);
                ?>
                <button type="button"
                        @click="pick('<?= $escaper->escapeJs($code) ?>')"
                        :class="selected === '<?= $escaper->escapeJs($code) ?>'
                            ? 'border-blue-500 bg-blue-50 ring-1 ring-blue-300'
                            : 'border-slate-200 bg-white hover:border-slate-300 hover:bg-slate-50 cursor-pointer'"
                        class="block w-full text-left rounded-lg border p-4 transition focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
                        :aria-pressed="selected === '<?= $escaper->escapeJs($code) ?>' ? 'true' : 'false'">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <strong class="text-sm font-semibold text-slate-900 truncate">
                                    <?= $escaper->escapeHtml($store['name']) ?>
                                </strong>
                                <span x-show="selected === '<?= $escaper->escapeJs($code) ?>'"
                                      class="inline-flex items-center rounded-full bg-blue-600 px-2 py-0.5 text-[10px] font-semibold text-white">
                                    <?= $escaper->escapeHtml(__('Selected')) ?>
                                </span>
                            </div>
                            <?php if ($address !== ''): ?>
                                <div class="mt-0.5 text-xs text-slate-600">
                                    <?= $escaper->escapeHtml($address) ?>
                                </div>
                            <?php endif; ?>
                            <?php if ($store['phone'] !== ''): ?>
                                <div class="mt-0.5 text-xs text-slate-500">
                                    <?= $escaper->escapeHtml($store['phone']) ?>
                                </div>
                            <?php endif; ?>
                            <?php if ($store['instructions'] !== ''): ?>
                                <div x-show="selected === '<?= $escaper->escapeJs($code) ?>'"
                                     class="mt-2 text-xs text-blue-800 bg-blue-50 rounded px-2 py-1.5">
                                    <?= $escaper->escapeHtml($store['instructions']) ?>
                                </div>
                            <?php endif; ?>
                        </div>
                        <div class="flex-shrink-0 mt-0.5">
                            <span :class="selected === '<?= $escaper->escapeJs($code) ?>' ? 'border-blue-600 bg-blue-600' : 'border-slate-300'"
                                  class="inline-flex h-5 w-5 items-center justify-center rounded-full border-2">
                                <svg x-show="selected === '<?= $escaper->escapeJs($code) ?>'"
                                     class="h-3 w-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                </svg>
                            </span>
                        </div>
                    </div>
                </button>
            <?php endforeach; ?>
        </div>

        <div x-show="selected !== ''"
             class="mt-4 rounded-md bg-blue-50 px-3 py-2.5 text-sm text-blue-900">
            <div class="flex items-start gap-2">
                <svg class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="flex-1 text-xs">
                    <?= $escaper->escapeHtml(__('We\'ll email you when your order is ready for pickup.')) ?>
                </div>
            </div>
        </div>
    </div>
</div>
