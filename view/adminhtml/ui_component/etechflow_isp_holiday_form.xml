<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_isp_holiday_form.etechflow_isp_holiday_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Holiday</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="ETechFlow\InStorePickup\Block\Adminhtml\Holiday\BackButton"/>
            <button name="delete" class="ETechFlow\InStorePickup\Block\Adminhtml\Holiday\DeleteButton"/>
            <button name="save" class="ETechFlow\InStorePickup\Block\Adminhtml\Holiday\SaveButton"/>
        </buttons>
        <namespace>etechflow_isp_holiday_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_isp_holiday_form.etechflow_isp_holiday_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_isp_holiday_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="ETechFlow\InStorePickup\Ui\Component\Form\HolidayDataProvider"
                      name="etechflow_isp_holiday_form_data_source">
            <settings>
                <requestFieldName>holiday_id</requestFieldName>
                <primaryFieldName>holiday_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Holiday Details</label>
        </settings>
        <htmlContent name="holiday_tz_note">
            <block name="holiday_tz_note_block"
                   class="ETechFlow\InStorePickup\Block\Adminhtml\Form\TimezoneNote"/>
        </htmlContent>

        <field name="holiday_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>holiday_id</dataScope>
            </settings>
        </field>
        <field name="name" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <dataScope>name</dataScope>
                <notice translate="true">Human-readable name — e.g. "Christmas Day", "Bank Holiday Monday".</notice>
                <tooltip>
                    <description translate="true">The holiday's display name. Shown to admins in the holiday grid and on the store-detail page when listing closed dates. Use the proper holiday name customers will recognise (e.g. "Boxing Day", "New Year's Day", "Bank Holiday Monday"). Internal-only holidays (e.g. "Annual Inventory Day") work too.</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="holiday_date" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Date</label>
                <dataScope>holiday_date</dataScope>
                <notice translate="true">When the holiday falls. Year matters only when "Annual" is off.</notice>
                <tooltip>
                    <description translate="true">The date the holiday applies. With "Annual" ON (toggle below), only the month-day part is used and the holiday repeats every year — perfect for Christmas Day, New Year's Day, etc. With "Annual" OFF, the full year-month-day applies — use for one-off holidays like Royal Weddings or Coronation days.</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <option name="dateFormat" xsi:type="string">y-MM-dd</option>
                            <option name="storeLocale" xsi:type="string">en_US</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
        <!-- v1.1.8: see amenity_form.xml for the toggle → select rationale. -->
        <field name="is_recurring" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Annual</label>
                <dataScope>is_recurring</dataScope>
                <notice translate="true">Yes = repeats every year on the same month-day. No = one-off date.</notice>
                <tooltip>
                    <description translate="true">Annual holidays (Christmas, New Year, Boxing Day) recur every year — no need to re-create them. One-off holidays (Royal coronations, store closures for renovation) use a specific year. The system uses the month-day from the Date field when Annual is Yes; the year is ignored.</description>
                </tooltip>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="is_closed" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Closed All Day</label>
                <dataScope>is_closed</dataScope>
                <notice translate="true">Yes = all stores closed. No = stores open with reduced hours (set below).</notice>
                <tooltip>
                    <description translate="true">For full closures (e.g. Christmas Day), keep this YES — all pickup stores show as closed and customers can't pick this date at checkout. For reduced-hours days (e.g. Christmas Eve, Bank Holidays where stores open later), set NO and fill the Reduced Open / Reduced Close times below.</description>
                </tooltip>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="reduced_open" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Reduced Open</label>
                <dataScope>reduced_open</dataScope>
                <notice translate="true">Required when "Closed All Day" is off. Accepts "10:00", "10am", "10", etc.</notice>
                <tooltip>
                    <description translate="true">Opening time on this reduced-hours date. Overrides the store's regular weekly opening hours for this specific date only. Flexible time format: "10:00", "10am", "10:30 AM" — anything sensible is normalised to HH:MM on save.</description>
                </tooltip>
                <imports>
                    <link name="visible">${ $.provider }:${ $.parentScope }.is_closed</link>
                </imports>
                <importsConfig>
                    <param name="visible" xsi:type="array">
                        <item name="0" xsi:type="boolean">true</item>
                        <item name="1" xsi:type="boolean">false</item>
                    </param>
                </importsConfig>
            </settings>
        </field>
        <field name="reduced_close" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Reduced Close</label>
                <dataScope>reduced_close</dataScope>
                <notice translate="true">Required when "Closed All Day" is off. Accepts "14:00", "2pm", "14", etc.</notice>
                <tooltip>
                    <description translate="true">Closing time on this reduced-hours date. Must be later than Reduced Open. Same flexible time format as Open: "14:00", "2pm", "2:30 PM".</description>
                </tooltip>
                <imports>
                    <link name="visible">${ $.provider }:${ $.parentScope }.is_closed</link>
                </imports>
                <importsConfig>
                    <param name="visible" xsi:type="array">
                        <item name="0" xsi:type="boolean">true</item>
                        <item name="1" xsi:type="boolean">false</item>
                    </param>
                </importsConfig>
            </settings>
        </field>
        <field name="country_code" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Country</label>
                <dataScope>country_code</dataScope>
                <notice translate="true">Optional 2-letter ISO code (GB / IE / US / …). Blank = custom holiday.</notice>
                <tooltip>
                    <description translate="true">Use this when importing public holidays from the etechflow:isp:import-holidays CLI — the country code tells the importer which national holiday calendar to pull. For custom internal holidays (annual inventory days, staff parties), leave blank. The code itself doesn't restrict which stores observe the holiday — that's handled by associating the holiday with specific stores after save.</description>
                </tooltip>
            </settings>
        </field>
    </fieldset>
</form>
