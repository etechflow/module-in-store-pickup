<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">etechflow_isp_amenity_form.etechflow_isp_amenity_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Amenity</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\BackButton"/>
            <button name="delete" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\DeleteButton"/>
            <button name="save" class="ETechFlow\InStorePickup\Block\Adminhtml\Amenity\SaveButton"/>
        </buttons>
        <namespace>etechflow_isp_amenity_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>etechflow_isp_amenity_form.etechflow_isp_amenity_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="etechflow_isp_amenity_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="ETechFlow\InStorePickup\Ui\Component\Form\AmenityDataProvider"
                      name="etechflow_isp_amenity_form_data_source">
            <settings>
                <requestFieldName>amenity_id</requestFieldName>
                <primaryFieldName>amenity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Amenity Details</label>
        </settings>

        <field name="amenity_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>amenity_id</dataScope>
            </settings>
        </field>
        <field name="label" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
                <notice translate="true">Customer-facing label — e.g. "Free parking", "Free coffee", "Wheelchair accessible".</notice>
                <tooltip>
                    <description translate="true">Text shown to shoppers on the store page next to the icon. Keep it short and concrete — "Free parking", "Wheelchair access", "Locker pickup 24/7", "Bike-friendly". Avoid vague labels like "Amenity" or "Feature".</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="code" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <dataScope>code</dataScope>
                <notice translate="true">URL-safe identifier — letters, numbers, dashes only. e.g. free-parking</notice>
                <tooltip>
                    <description translate="true">Permanent unique handle used in URLs and the database. Pick something short and descriptive (e.g. "free-parking"). CANNOT be changed after save without breaking existing store associations.</description>
                </tooltip>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="icon" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Icon</label>
                <dataScope>icon</dataScope>
                <notice translate="true">Optional Tabler Icons name (e.g. "parking", "coffee", "wheelchair"). Browse: tabler-icons.io</notice>
                <tooltip>
                    <description translate="true">Icon name from the free Tabler Icons set at tabler-icons.io. Browse, find one matching the amenity, paste the name here (no .svg extension). Examples: parking, accessible, wifi, baby-carriage, paw, coffee, bike, charger. Leave blank for a generic dot.</description>
                </tooltip>
            </settings>
        </field>
        <field name="sort_order" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Sort Order</label>
                <dataScope>sort_order</dataScope>
                <notice translate="true">Display order in the store amenities list. Lower = first. Use 10, 20, 30…</notice>
                <tooltip>
                    <description translate="true">Controls order on the store-detail page. Lower numbers first. Use multiples of 10 so you can insert new amenities (e.g. add "Bike racks" as 15 between 10 and 20) without renumbering.</description>
                </tooltip>
            </settings>
        </field>
        <!--
            v1.1.8: switched from formElement="checkbox" (with valueMap +
            <prefer>toggle</prefer>) to formElement="select" + Magento's
            standard Yesno source model. The checkbox toggle's display
            state proved unreliable across Hyva Commerce admin themes
            (display showed OFF even when DB held 1); the Yes/No dropdown
            is what Magento Core uses for every system-config is_active
            field and renders identically everywhere. UX trade-off: a
            dropdown instead of a toggle. Data shape is unchanged (0/1).
        -->
        <field name="is_active" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
                <notice translate="true">Yes = show on storefront. No = hide without deleting.</notice>
                <tooltip>
                    <description translate="true">Inactive amenities are hidden on the storefront but kept in admin + still associated with their stores. Use for seasonal items ("Christmas gift wrapping") or temporary removal during renovation.</description>
                </tooltip>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
